task.wait(60)

-- CONFIG
getgenv().Config = {
    ["Target"] = {
        ["Rebirth"] = 9,
        ["Rank"] = 11
    }
}

-- LOAD DATA PS99
local Client = game:GetService("ReplicatedStorage")
    :WaitForChild("Library")
    :WaitForChild("Client")

local Save = require(Client.Save)

local function GetData()
    return Save.Get()
end

-- CHECK ĐIỀU KIỆN
local function canKick()
    local data = GetData()

    local rank = data.Rank or 0
    local rebirth = data.Rebirths or 0

    local targetRank = getgenv().Config["Target"]["Rank"]
    local targetRebirth = getgenv().Config["Target"]["Rebirth"]

    return rebirth >= targetRebirth and rank >= targetRank
end

-- LOOP CHECK
task.spawn(function()
    while task.wait(2) do
        if canKick() then
            game.Players.LocalPlayer:Kick(
                "Reached Target | Rank: "
                .. tostring(getgenv().Config["Target"]["Rank"])
                .. " | Rebirth: "
                .. tostring(getgenv().Config["Target"]["Rebirth"])
            )

            break
        end
    end
end)
