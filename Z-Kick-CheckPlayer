task.wait(5)
local Players = game:GetService("Players")

-- ===== CẤU HÌNH =====
local CHECK_ALL_PLACES = false
local TARGET_PLACEID = 140403681187145
-- ====================

-- Bỏ qua từ 23:00 đến 23:59 giờ Việt Nam
local function IsExcludedHour()
    local utc = os.date("!*t")
    local vnHour = (utc.hour + 7) % 24
    return vnHour == 23
end

local function Check()
    if IsExcludedHour() then
        return
    end

    if not CHECK_ALL_PLACES and game.PlaceId ~= TARGET_PLACEID then
        return
    end

    if #Players:GetPlayers() > 1 then
        Players.LocalPlayer:Kick("Có người khác trong server")
    end
end

-- Check mỗi 5 phút
task.spawn(function()
    while true do
        task.wait(300)
        Check()
    end
end)
