task.wait(5)
local Players = game:GetService("Players")

-- ===== CẤU HÌNH =====

local CHECK_ALL_PLACES = false -- true = mọi world, false = chỉ PlaceId bên dưới

local TARGET_PLACEID = 140403681187145

-- ====================

-- Bỏ qua từ 23:00 đến 23:59 giờ Việt Nam
local function IsExcludedHour()
    local utc = os.date("!*t")
    local vnHour = (utc.hour + 7) % 24
    return vnHour == 23
end

local function Check()
    -- Không kiểm tra trong khung giờ bỏ qua
    if IsExcludedHour() then
        return
    end

    -- Chỉ kiểm tra PlaceId chỉ định
    if not CHECK_ALL_PLACES and game.PlaceId ~= TARGET_PLACEID then
        return
    end

    -- Có người khác trong server
    if #Players:GetPlayers() > 1 then
        Players.LocalPlayer:Kick("Có người khác trong server")
    end
end

-- Check khi script bắt đầu
task.wait(5)
Check()

-- Check khi có người mới vào
Players.PlayerAdded:Connect(function(plr)
    if plr ~= Players.LocalPlayer then
        Check()
    end
end)
